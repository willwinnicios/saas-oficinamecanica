// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Company {
  id        String   @id @default(cuid())
  name      String
  cnpj      String?  @unique
  email     String?
  phone     String?
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users                 User[]
  customers             Customer[]
  parts                 Part[]
  suppliers             Supplier[]
  serviceOrders         ServiceOrder[]
  quotes                Quote[]
  financialTransactions FinancialTransaction[]
  employees             Employee[]
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  role          String    @default("USER")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Customer {
  id        String   @id @default(cuid())
  name      String
  document  String? // CPF/CNPJ
  phone     String?
  whatsapp  String?
  email     String?
  address   String?
  notes     String?
  status    String   @default("ACTIVE")
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vehicles      Vehicle[]
  serviceOrders ServiceOrder[]
  quotes        Quote[]
}

model Vehicle {
  id             String   @id @default(cuid())
  brand          String
  model          String
  year           Int?
  plate          String   @unique
  color          String?
  renavam        String?
  chassi         String?
  mileage        Int?
  notes          String?
  customerId     String
  customer       Customer @relation(fields: [customerId], references: [id])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  serviceOrders  ServiceOrder[]
  quotes         Quote[]
}

model Part {
  id            String   @id @default(cuid())
  name          String
  code          String?
  category      String?
  brand         String?
  compatibility String?
  quantity      Int      @default(0)
  minQuantity   Int      @default(0)
  costPrice     Decimal  @default(0)
  salePrice     Decimal  @default(0)
  location      String?
  status        String   @default("ACTIVE")
  companyId     String
  company       Company  @relation(fields: [companyId], references: [id])
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  movements StockMovement[]
  orderItems ServiceOrderItem[]
  quoteItems QuoteItem[]
}

model StockMovement {
  id        String   @id @default(cuid())
  partId    String
  part      Part     @relation(fields: [partId], references: [id])
  type      String // IN, OUT
  quantity  Int
  reason    String?
  createdAt DateTime @default(now())
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  cnpj      String?  @unique
  phone     String?
  whatsapp  String?
  email     String?
  site      String?
  address   String?
  type      String?
  notes     String?
  status    String   @default("ACTIVE")
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parts            Part[]
  purchaseRequests PurchaseRequest[]
}

model ServiceOrder {
  id               String   @id @default(cuid())
  number           Int      @unique @default(autoincrement())
  status           String   @default("OPEN")
  entryDate        DateTime @default(now())
  deliveryForecast DateTime?
  problemReported  String?
  diagnosis        String?
  discount         Decimal  @default(0)
  totalAmount      Decimal  @default(0)
  paymentMethod    String?
  internalNotes    String?
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id])
  vehicleId        String
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items ServiceOrderItem[]
}

model ServiceOrderItem {
  id             String   @id @default(cuid())
  serviceOrderId String
  serviceOrder   ServiceOrder @relation(fields: [serviceOrderId], references: [id])
  type           String // SERVICE, PART
  description    String
  quantity       Int      @default(1)
  unitPrice      Decimal  @default(0)
  totalPrice     Decimal  @default(0)
  partId         String?
  part           Part?    @relation(fields: [partId], references: [id])
}

model Quote {
  id               String   @id @default(cuid())
  status           String   @default("DRAFT")
  validity         DateTime?
  discount         Decimal  @default(0)
  totalAmount      Decimal  @default(0)
  companyId        String
  company          Company  @relation(fields: [companyId], references: [id])
  customerId       String
  customer         Customer @relation(fields: [customerId], references: [id])
  vehicleId        String
  vehicle          Vehicle  @relation(fields: [vehicleId], references: [id])
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  items QuoteItem[]
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  quote       Quote    @relation(fields: [quoteId], references: [id])
  type        String // SERVICE, PART
  description String
  quantity    Int      @default(1)
  unitPrice   Decimal  @default(0)
  totalPrice  Decimal  @default(0)
  partId      String?
  part        Part?    @relation(fields: [partId], references: [id])
}

model PurchaseRequest {
  id            String   @id @default(cuid())
  description   String
  quantity      Int
  reason        String?
  estimatedPrice Decimal?
  status        String   @default("REQUESTED")
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  companyId     String
  company       Company   @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model FinancialTransaction {
  id          String   @id @default(cuid())
  type        String // INCOME, EXPENSE
  category    String?
  amount      Decimal
  description String?
  dueDate     DateTime
  paymentDate DateTime?
  status      String   @default("PENDING")
  paymentMethod String?
  companyId   String
  company     Company  @relation(fields: [companyId], references: [id])
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Employee {
  id        String   @id @default(cuid())
  name      String
  email     String?
  phone     String?
  role      String // ADMIN, MANAGER, MECHANIC, FINANCE, ATTENDANT
  companyId String
  company   Company  @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
